# .gitignore for .NET and Angular (Node.js)

# [Visual Studio]
.vs/
*.user
*.userosscache
*.sln.docstates

# [Build Outputs]
bin/
obj/
[Ee]xpress/
TestResults/
[Dd]ebug/
[Rr]elease/

# [Node / Angular]
node_modules/
dist/
.angular/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# [Environment Files]
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# [Operating System]
Thmubs.db
ehthumbs.db
Desktop.ini
.DS_Store

# [IDE - VS Code]
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# [Temp / Logs]
logs/
*.log
publish/
deploy-temp/
